{
  "expo": {
    "name": "Rose",
    "slug": "rose-azuria",
    "version": "0.0.1",
    "orientation": "portrait",
    "icon": "./assets/logo.png",
    "scheme": "restodepenses",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.azuria.rose"
    },
    "android": {
      "package": "com.azuria.rose",
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.CAMERA"
      ]
    },
    "plugins": [
      [
        "expo-image-picker",
        {
          "photosPermission": "Pour photographier vos factures."
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Pour photographier vos factures."
        }
      ],
      [
        "react-native-document-scanner-plugin",
        {
          "cameraPermission": "Pour scanner vos factures."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "74e50f5c-dab9-4882-8c15-2c17b8c3342e"
      }
    },
    "owner": "1313nrv"
  }
}
