# Copier en .env (jamais commiter le .env réel)
# Récupérables dans Supabase Studio → Project Settings → API
VITE_SUPABASE_URL=https://xxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOi...

# Pour Expo (mêmes valeurs, préfixe différent)
EXPO_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...

# /!\ La clé ANTHROPIC_API_KEY ne va JAMAIS ici.
# Elle vit uniquement en secret côté Edge Function :
#   supabase secrets set ANTHROPIC_API_KEY=sk-ant-...
